<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Faculty -->
    <record id="view_op_faculty_form" model="ir.ui.view">
        <field name="name">op.faculty.form</field>
        <field name="model">op.faculty</field>
        <field name="arch" type="xml">
            <form string="Faculty">
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="middle_name"/>
                            <field name="last_name"/>
                            <field name="hire_date"/>
                        </group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="department_id"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="street"/>
                        <field name="street2"/>
                        <field name="city"/>
                        <field name="state_id"/>
                        <field name="zip"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View for Faculty -->
    <record id="view_op_faculty_tree" model="ir.ui.view">
        <field name="name">op.faculty.tree</field>
        <field name="model">op.faculty</field>
        <field name="arch" type="xml">
            <tree string="Faculties">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>

    <!-- Action for Faculty -->
    <record id="action_op_faculty" model="ir.actions.act_window">
        <field name="name">Faculty</field>
        <field name="res_model">op.faculty</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>