<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Subject -->
    <record id="view_op_subject_form" model="ir.ui.view">
        <field name="name">op.subject.form</field>
        <field name="model">op.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="faculty_id"/>
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View for Subject -->
    <record id="view_op_subject_tree" model="ir.ui.view">
        <field name="name">op.subject.tree</field>
        <field name="model">op.subject</field>
        <field name="arch" type="xml">
            <tree string="Subjects">
                <field name="name"/>
                <field name="faculty_id"/>
            </tree>
        </field>
    </record>

    <!-- Action for Subject -->
    <record id="action_op_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">op.subject</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>