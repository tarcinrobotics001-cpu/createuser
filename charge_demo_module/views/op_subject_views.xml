<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Subject -->
    <record id="view_op_subject_form" model="ir.ui.view">
        <field name="name">op.subject.form</field>
        <field name="model">op.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="faculty_id"/>
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View for Subject -->
    <record id="view_op_subject_list" model="ir.ui.view">
        <field name="name">op.subject.list</field>
        <field name="model">op.subject</field>
        <field name="arch" type="xml">
            <list string="Subjects">
                <field name="name"/>
                <field name="faculty_id"/>
            </list>
        </field>
    </record>

    <!-- Action for Subject -->
    <record id="action_op_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">op.subject</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>