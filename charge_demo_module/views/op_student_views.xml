<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Student -->
    <record id="view_op_student_form" model="ir.ui.view">
        <field name="name">op.student.form</field>
        <field name="model">op.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_create_user"
                            string="Create User"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('user_id', '!=', False)]}"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="birth_date"/>
                        </group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="department_id"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="street"/>
                        <field name="street2"/>
                        <field name="city"/>
                        <field name="state_id"/>
                        <field name="zip"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View for Student -->
    <record id="view_op_student_list" model="ir.ui.view">
        <field name="name">op.student.list</field>
        <field name="model">op.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <!-- Action for Student -->
    <record id="action_op_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">op.student</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_student', '=', True)]</field>
        <field name="context">{'default_is_student': True, 'default_company_type': 'person'}</field>
    </record>
</odoo>