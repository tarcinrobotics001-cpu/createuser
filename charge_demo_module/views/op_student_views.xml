<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Student -->
    <record id="view_op_student_form" model="ir.ui.view">
        <field name="name">op.student.form</field>
        <field name="model">op.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <sheet>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="middle_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                        </group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="department_id"/>
                        </group>
                    </group>
                    <group string="Address">
                        <field name="street"/>
                        <field name="street2"/>
                        <field name="city"/>
                        <field name="state_id"/>
                        <field name="zip"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View for Student -->
    <record id="view_op_student_list" model="ir.ui.view">
        <field name="name">op.student.list</field>
        <field name="model">op.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <!-- Action for Student -->
    <record id="action_op_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">op.student</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>