<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Assignment -->
    <record id="view_op_assignment_form" model="ir.ui.view">
        <field name="name">op.assignment.form</field>
        <field name="model">op.assignment</field>
        <field name="arch" type="xml">
            <form string="Assignment">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="subject_id"/>
                        <field name="faculty_id"/>
                        <field name="student_id"/>
                        <field name="due_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View for Assignment -->
    <record id="view_op_assignment_list" model="ir.ui.view">
        <field name="name">op.assignment.list</field>
        <field name="model">op.assignment</field>
        <field name="arch" type="xml">
            <list string="Assignments">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="faculty_id"/>
                <field name="student_id"/>
                <field name="due_date"/>
            </list>
        </field>
    </record>

    <!-- Action for Assignment -->
    <record id="action_op_assignment" model="ir.actions.act_window">
        <field name="name">Assignments</field>
        <field name="res_model">op.assignment</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>