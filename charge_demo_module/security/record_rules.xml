<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rules for Students -->
        <record id="op_student_student_rule" model="ir.rule">
            <field name="name">Student: See Own Record</field>
            <field name="model_id" ref="charge_demo_module.model_op_student"/>
            <field name="groups" eval="[(4, ref('group_openeducat_student_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('id', '=', user.partner_id.id)]</field>
        </record>

        <record id="op_assignment_student_rule" model="ir.rule">
            <field name="name">Student: See Own Assignments</field>
            <field name="model_id" ref="charge_demo_module.model_op_assignment"/>
            <field name="groups" eval="[(4, ref('group_openeducat_student_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('student_id', '=', user.student_id.id)]</field>
        </record>

        <record id="op_subject_student_rule" model="ir.rule">
            <field name="name">Student: See Own Subjects</field>
            <field name="model_id" ref="charge_demo_module.model_op_subject"/>
            <field name="groups" eval="[(4, ref('group_openeducat_student_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('student_ids', 'in', user.student_id.id)]</field>
        </record>

        <!-- Record Rules for Faculty -->
        <record id="op_student_faculty_rule" model="ir.rule">
            <field name="name">Faculty: Manage Students in Own Department</field>
            <field name="model_id" ref="charge_demo_module.model_op_student"/>
            <field name="groups" eval="[(4, ref('group_openeducat_faculty_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('department_id', '=', user.faculty_id.department_id.id)]</field>
        </record>

        <record id="op_faculty_faculty_rule" model="ir.rule">
            <field name="name">Faculty: See Faculty in Own Department</field>
            <field name="model_id" ref="charge_demo_module.model_op_faculty"/>
            <field name="groups" eval="[(4, ref('group_openeducat_faculty_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">[('department_id', '=', user.faculty_id.department_id.id)]</field>
        </record>

        <record id="op_subject_faculty_rule" model="ir.rule">
            <field name="name">Faculty: See Own Subjects</field>
            <field name="model_id" ref="charge_demo_module.model_op_subject"/>
            <field name="groups" eval="[(4, ref('group_openeducat_faculty_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('faculty_id', '=', user.faculty_id.id)]</field>
        </record>

        <record id="op_assignment_faculty_rule" model="ir.rule">
            <field name="name">Faculty: See Own Assignments</field>
            <field name="model_id" ref="charge_demo_module.model_op_assignment"/>
            <field name="groups" eval="[(4, ref('group_openeducat_faculty_demo'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[('faculty_id', '=', user.faculty_id.id)]</field>
        </record>
    </data>
</odoo>