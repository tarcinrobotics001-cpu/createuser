                (4, ref('charge_demo_module.user_faculty_7')),
                (4, ref('charge_demo_module.user_faculty_8')),
                (4, ref('charge_demo_module.user_faculty_9')),
                (4, ref('charge_demo_module.user_faculty_10')),
                (4, ref('base.user_admin'))
            ]"/>
        </record>
    </data>
</odoo>