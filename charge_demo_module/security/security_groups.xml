<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Security Category -->
        <record id="module_category_openeducat_demo" model="ir.module.category">
            <field name="name">Education Demo</field>
            <field name="description">User groups for the Education Demo Module</field>
            <field name="sequence">20</field>
        </record>

        <!-- Student Group -->
        <record id="group_openeducat_student_demo" model="res.groups">
            <field name="name">Student (Demo)</field>
            <field name="category_id" ref="module_category_openeducat_demo"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <!-- Faculty Group -->
        <record id="group_openeducat_faculty_demo" model="res.groups">
            <field name="name">Faculty (Demo)</field>
            <field name="category_id" ref="module_category_openeducat_demo"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>