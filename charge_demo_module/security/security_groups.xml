            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
            <field name="users" eval="[
                (4, ref('charge_demo_module.user_student_1')),
                (4, ref('charge_demo_module.user_student_2')),
                (4, ref('charge_demo_module.user_student_3')),
                (4, ref('charge_demo_module.user_student_4')),
                (4, ref('charge_demo_module.user_student_5')),
                (4, ref('charge_demo_module.user_student_6')),
                (4, ref('charge_demo_module.user_student_7')),
                (4, ref('charge_demo_module.user_student_8')),
                (4, ref('charge_demo_module.user_student_9')),
                (4, ref('charge_demo_module.user_student_10')),
